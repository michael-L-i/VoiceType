<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleName</key>
    <string>VoiceType</string>
    <key>CFBundleDisplayName</key>
    <string>VoiceType</string>
    <key>CFBundleIdentifier</key>
    <string>com.voicetype.app</string>
    <key>CFBundleExecutable</key>
    <string>VoiceType</string>
    <key>CFBundleIconFile</key>
    <string>AppIcon</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0.0</string>
    <key>CFBundleVersion</key>
    <string>1.0.0</string>
    <key>LSMinimumSystemVersion</key>
    <string>26.0</string>
    <!-- Regular Dock app: a visible icon, app-switcher entry, and a main window.
         (Previously LSUIElement=true ran it as a faceless menu-bar agent.) -->
    <!-- Never run two copies at once. Two instances share the bundle ID and
         fight over the menu bar, the onboarding window, and the system
         permission prompts. This blocks a second launch of *this* bundle; the
         AppDelegate also defers to an already-running copy at a different path
         (e.g. an installed build vs. a dev build). -->
    <key>LSMultipleInstancesProhibited</key>
    <true/>
    <key>NSMicrophoneUsageDescription</key>
    <string>VoiceType listens while you hold the dictation key. Audio stays on your device.</string>
    <key>NSSpeechRecognitionUsageDescription</key>
    <string>VoiceType converts your speech to text using Apple's on-device model.</string>
    <!-- Sparkle auto-updates: signed appcast served from the latest GitHub
         release. SUPublicEDKey verifies every update's EdDSA signature; the
         matching private key lives only in the maintainer's Keychain / a CI
         secret and is never committed. -->
    <key>SUFeedURL</key>
    <string>https://github.com/michael-L-i/VoiceType/releases/latest/download/appcast.xml</string>
    <key>SUPublicEDKey</key>
    <string>AsC+tvEsbLpvnzz128pWnWzf7Zc8r9fQCNSZZaMkuSo=</string>
    <key>SUEnableAutomaticChecks</key>
    <true/>
    <key>SUScheduledCheckInterval</key>
    <integer>86400</integer>
</dict>
</plist>
